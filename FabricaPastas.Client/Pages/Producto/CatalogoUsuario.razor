@page "/catalogo-usuario"
@inject FabricaPastas.Client.Servicios.IHTTPServicio http
@inject CarritoServicio carritoServicio
@inject NavigationManager navigationManager
@inject IJSRuntime JSRuntime

<div class="container py-4">

    <!-- 🔹 Encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold text-danger">
            🍝 Catálogo de Productos
        </h1>

        <button class="btn btn-outline-primary fw-semibold" @onclick="VolverInicio">
            <i class="bi bi-arrow-left-circle"></i> Volver al inicio
        </button>
    </div>

    <!-- 🔹 Info de lista aplicada -->
    <div class="alert alert-light border d-flex justify-content-between align-items-center mb-4">
        <div class="text-muted">
            Lista aplicada: <span class="fw-bold">@listaPrecioTipo</span>
        </div>
    </div>

    <!-- 🔹 Listado de productos -->
    @if (productos == null)
    {
        <div class="text-center text-muted mt-5">
            <div class="spinner-border text-danger mb-3"></div>
            <p>Cargando productos...</p>
        </div>
    }
    else if (!productos.Any())
    {
        <p class="text-center text-muted">No hay productos disponibles.</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var p in productos)
            {
                var precioMostrar = ObtenerPrecioParaProducto(p.Id, p.PrecioBase);

                <div class="col">
                    <div class="card h-100 shadow-sm border-0">

                        @* Imagen: en tu proyecto actualizado la entidad usa ImagenUrl.
                           Si en tu DTO seguís usando Imagen_Url, lo respetamos. *@
                        <img src="@ResolverImagen(p)"
                             class="card-img-top rounded-top"
                             alt="@p.Nombre"
                             style="object-fit: cover; height: 220px;">

                        <div class="card-body">
                            <h5 class="card-title text-danger fw-bold">@p.Nombre</h5>
                            <p class="card-text text-secondary">@p.Descripcion</p>

                            <!-- ✅ Precio por lista (o base si no hay detalle) -->
                            <p class="fw-bold text-success fs-5">💲@precioMostrar</p>

                            <!-- 🔹 Selector de cantidad -->
                            <div class="input-group mt-2">
                                <span class="input-group-text">Cantidad</span>
                                <input type="number"
                                       class="form-control text-center"
                                       min="1"
                                       value="@obtenerCantidad(p.Id)"
                                       @oninput="(e) => cambiarCantidad(p.Id, e)" />
                            </div>
                        </div>

                        <div class="card-footer bg-transparent border-0 text-center">
                            <button class="btn btn-success w-100 fw-semibold mt-2" @onclick="() => AgregarAlCarrito(p)">
                                🛒 Agregar al carrito
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- 🔹 Carrito -->
    <div class="carrito-container mt-5 p-4 bg-light rounded shadow-sm">

        <h4 class="fw-bold text-dark mb-3">🛍️ Carrito de compras</h4>

        @if (carritoServicio.Items.Any())
        {
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-danger">
                        <tr>
                            <th>Producto</th>
                            <th>Precio</th>
                            <th>Cantidad</th>
                            <th>Subtotal</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in carritoServicio.Items)
                        {
                            <tr>
                                <td>@item.Nombre</td>
                                <td>$@item.PrecioUnitario</td>
                                <td>@item.Cantidad</td>
                                <td>$@item.Subtotal</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => QuitarDelCarrito(item.ProductoId)">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- 🔹 Método de pago -->
@*             <div class="mt-4">
                <h5 class="fw-bold mb-2">💳 Método de pago</h5>

                <div class="form-check">
                    <input class="form-check-input" type="radio" id="efectivo" name="metodoPago"
                           value="Efectivo" @onchange="SeleccionarMetodoPago" checked="@("Efectivo" == metodoPago)">
                    <label class="form-check-label" for="efectivo">Efectivo</label>
                </div>

                <div class="form-check">
                    <input class="form-check-input" type="radio" id="transferencia" name="metodoPago"
                           value="Transferencia" @onchange="SeleccionarMetodoPago" checked="@("Transferencia" == metodoPago)">
                    <label class="form-check-label" for="transferencia">Transferencia</label>
                </div>
            </div> *@

            <div class="text-end mt-4">
                <h5 class="fw-bold">Total: 💰 $@carritoServicio.ObtenerTotal()</h5>
                <button class="btn btn-primary fw-semibold" @onclick="FinalizarCompra">
                    Finalizar compra
                </button>
            </div>
        }
        else
        {
            <div class="text-center text-muted py-3">
                <p>Tu carrito está vacío. Agregá algunos productos para comenzar 🍝</p>
            </div>
        }
    </div>

</div>

@* (Bootstrap Icons ya lo tenés en index.html; si querés dejarlo, no rompe) *@
@* <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"> *@

<style>
    body {
        background: url('/images/fondo-nonna.jpg') no-repeat center center fixed;
        background-size: cover;
    }

    .carrito-container {
        background-color: rgba(255, 255, 255, 0.9);
    }

    .card:hover {
        transform: scale(1.03);
        transition: transform 0.2s ease-in-out;
    }

    .btn-success:hover {
        background-color: #28a745;
        transform: scale(1.05);
    }

    .btn-outline-primary:hover {
        background-color: #007bff;
        color: white;
    }
</style>

@code {
    // ✅ Usamos entidad Producto del proyecto actualizado (tiene ImagenUrl, PrecioBase, Activo, etc.)
    private List<FabricaPastas.BD.Data.Entity.Producto>? productos;

    // ✅ Traemos detalles de lista para resolver precios
    private List<FabricaPastas.BD.Data.Entity.Detalle_Lista_Precio> detalles = new();

    // "Minorista" / "Mayorista" (se guarda en localStorage al loguear)
    private string listaPrecioTipo = "Minorista";

    private Dictionary<int, int> cantidades = new(); // cantidad por producto
    private string metodoPago = "Efectivo"; // por defecto

    protected override async Task OnInitializedAsync()
    {
        // 1) Leer tipo de lista desde localStorage (si no existe, Minorista)
        var almacenado = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "listaPrecioTipo");
        if (!string.IsNullOrWhiteSpace(almacenado))
            listaPrecioTipo = almacenado;

        // 2) Productos
        var respuesta = await http.Get<List<FabricaPastas.BD.Data.Entity.Producto>>("api/Producto");
        if (respuesta.Error)
        {
            Console.WriteLine("Error al cargar productos");
            productos = new();
            return;
        }

        productos = (respuesta.Respuesta ?? new())
            .Where(p => p.Activo)
            .ToList();

        // 3) Detalles de lista de precio (si falla, igual funciona con PrecioBase)
        var respDetalles = await http.Get<List<FabricaPastas.BD.Data.Entity.Detalle_Lista_Precio>>("api/Detalle_Lista_Precio");
        if (!respDetalles.Error && respDetalles.Respuesta != null)
            detalles = respDetalles.Respuesta;
    }

    private int obtenerCantidad(int id)
    {
        return cantidades.ContainsKey(id) ? cantidades[id] : 1;
    }

    private void cambiarCantidad(int id, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int nuevaCantidad))
            cantidades[id] = Math.Max(1, nuevaCantidad);
    }

    // ✅ Precio final según lista (si no hay detalle => PrecioBase)
    private decimal ObtenerPrecioParaProducto(int productoId, decimal precioBase)
    {
        // Nota: esto depende de que el GET /api/Detalle_Lista_Precio
        // incluya Lista_Precio (navegación) para leer Tipo.
        var detalle = detalles.FirstOrDefault(d =>
            d.Producto_Id == productoId &&
            d.Lista_Precio != null &&
            d.Lista_Precio.Tipo == listaPrecioTipo);

        return detalle != null ? detalle.Precio : precioBase;
    }

    private void AgregarAlCarrito(FabricaPastas.BD.Data.Entity.Producto producto)
    {
        int cantidad = obtenerCantidad(producto.Id);

        var precioUnitario = ObtenerPrecioParaProducto(producto.Id, producto.PrecioBase);

        var item = new CarritoDTO
        {
            ProductoId = producto.Id,
            Nombre = producto.Nombre ?? "",
            Descripcion = producto.Descripcion ?? "",
            PrecioUnitario = precioUnitario,
            Cantidad = cantidad
        };

        carritoServicio.Agregar(item);
    }

    private void QuitarDelCarrito(int idProducto)
    {
        carritoServicio.Eliminar(idProducto);
    }

    private void SeleccionarMetodoPago(ChangeEventArgs e)
    {
        metodoPago = e.Value?.ToString() ?? "Efectivo";
        carritoServicio.AsignarMetodoPago(metodoPago);
    }

    private void FinalizarCompra()
    {
        navigationManager.NavigateTo("/pedido");
    }

    private void VolverInicio()
    {
        navigationManager.NavigateTo("/InicioUsuario");
    }

    // ✅ Resuelve imagen compatible con tu modelo nuevo
    private string ResolverImagen(FabricaPastas.BD.Data.Entity.Producto p)
    {
        // Si viene null/vacía, mostramos un placeholder simple
        if (string.IsNullOrWhiteSpace(p.ImagenUrl))
            return $"{navigationManager.BaseUri.TrimEnd('/')}/images/sin-imagen.png";

        // Si ya viene con "/images/..." lo devolvemos
        if (p.ImagenUrl.StartsWith("/"))
            return $"{navigationManager.BaseUri.TrimEnd('/')}{p.ImagenUrl}";

        // Si viene "images/..." o "http..."
        if (p.ImagenUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return p.ImagenUrl;

        return $"{navigationManager.BaseUri.TrimEnd('/')}/{p.ImagenUrl.TrimStart('/')}";
    }
}
