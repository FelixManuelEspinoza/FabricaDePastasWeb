@page "/Catalogo"
@inject NavigationManager navigationManager

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body text-center p-5">

                    <!-- Título con estilo -->
                    <h1 class="card-title mb-4 fw-bold text-warning">
                        🍝 Catálogo de Productos
                    </h1>
                    <p class="text-muted mb-4">
                        Descubrí nuestras pastas artesanales y promociones especiales.
                    </p>

                    <!-- Botonera central -->
                    <div class="d-grid gap-3 col-10 mx-auto">

                        <!-- Ver productos -->
                        <button class="btn btn-primary btn-lg fw-semibold shadow-sm" @onclick="ListaProducto">
                            <i class="bi bi-box-seam me-2"></i> Ver productos
                        </button>

                        <!-- Ver promociones -->
                        <a class="btn btn-success btn-lg fw-semibold shadow-sm" href="/api/Promocion/Lista">
                            <i class="bi bi-tags me-2"></i> Ver promociones
                        </a>

                        <!-- Volver al inicio -->
                        <button class="btn btn-outline-danger btn-lg fw-semibold shadow-sm" @onclick="Cancelar">
                            <i class="bi bi-x-circle me-2"></i> Volver al inicio
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
   
    private void ListaProducto() => navigationManager.NavigateTo("/api/Producto/Lista");

   
    private void Cancelar() => navigationManager.NavigateTo("/");
}
