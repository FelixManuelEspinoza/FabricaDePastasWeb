@page "/admin/pedidos/detalle/{Id:int}"
@layout FabricaPastas.Client.Layout.AdminLayout

@inject FabricaPastas.Client.Servicios.IHTTPServicio http
@inject NavigationManager nav

@using FabricaPastas.BD.Data.Entity

<div class="container my-4">

    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
        <div>
            <h3 class="mb-0">📄 Detalle de pedido</h3>
            <small class="text-muted">Vista solo lectura (admin)</small>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="@(() => nav.NavigateTo("/admin/pedidos"))">
                ← Volver
            </button>

            @if (Pedido != null)
            {
                <button class="btn btn-primary" @onclick="@(() => DescargarRecibo(Pedido.Id))">
                    🧾 PDF
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Mensaje))
    {
        <div class="alert alert-danger">❌ @Mensaje</div>
    }
    else if (Cargando)
    {
        <div class="alert alert-secondary">🔄 Cargando pedido...</div>
    }
    else if (Pedido == null)
    {
        <div class="alert alert-warning">⚠️ No se encontró el pedido.</div>
    }
    else
    {
        var u = Pedido.Usuario;
        var tipo = u?.Tipo_Cliente?.Descripcion ?? "-";
        var esMayorista = (tipo ?? "").ToLower().Contains("mayor");

        <div class="row g-3">

            <!-- Datos generales -->
            <div class="col-lg-6">
                <div class="card shadow-sm rounded-4">
                    <div class="card-body">
                        <h5 class="fw-semibold mb-3">🧾 Datos del pedido</h5>

                        <div class="row g-2">
                            <div class="col-6">
                                <div class="text-muted small">Código</div>
                                <div class="fw-semibold">@Pedido.CodigoPedido</div>
                            </div>

                            <div class="col-6">
                                <div class="text-muted small">Estado</div>
                                <div>
                                    <span class="badge bg-secondary">@EstadoDescripcion(Pedido.Estado_Pedido_Id)</span>
                                </div>
                            </div>

                            <div class="col-6">
                                <div class="text-muted small">Fecha pedido</div>
                                <div>@Pedido.FechaPedido.ToString("dd/MM/yyyy")</div>
                            </div>

                            <div class="col-6">
                                <div class="text-muted small">Fecha entrega</div>
                                <div>@(Pedido.FechaEntrega.HasValue? Pedido.FechaEntrega.Value.ToString("dd/MM/yyyy") : "-")</div>
                            </div>

                            <div class="col-12">
                                <div class="text-muted small">Observaciones catering</div>
                                <div>@(string.IsNullOrWhiteSpace(Pedido.ObservacionesCatering) ? "-" : Pedido.ObservacionesCatering)</div>
                            </div>

                            <div class="col-12 mt-2">
                                <div class="text-muted small">Total</div>
                                <div class="fs-5 fw-bold">$ @Pedido.Total.ToString("N2")</div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- Datos usuario -->
            <div class="col-lg-6">
                <div class="card shadow-sm rounded-4">
                    <div class="card-body">
                        <h5 class="fw-semibold mb-3">👤 Usuario</h5>

                        <div class="row g-2">
                            <div class="col-6">
                                <div class="text-muted small">Nombre</div>
                                <div>@(u?.Nombre ?? "-")</div>
                            </div>

                            <div class="col-6">
                                <div class="text-muted small">Apellido</div>
                                <div>@(u?.Apellido ?? "-")</div>
                            </div>

                            <div class="col-6">
                                <div class="text-muted small">Usuario</div>
                                <div class="fw-semibold">@(u?.NombreUsuario ?? "-")</div>
                            </div>

                            <div class="col-6">
                                <div class="text-muted small">Email</div>
                                <div>@(u?.Email ?? "-")</div>
                            </div>

                            <div class="col-6">
                                <div class="text-muted small">Tipo cliente</div>
                                <div>
                                    <span class="badge @(esMayorista ? "bg-warning text-dark" : "bg-info")">@tipo</span>
                                </div>
                            </div>

                            <div class="col-6">
                                <div class="text-muted small">Teléfono</div>
                                <div>@(u?.Telefono ?? "-")</div>
                            </div>

                            <div class="col-12">
                                <div class="text-muted small">Dirección</div>
                                <div>@(u?.Direccion ?? "-")</div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- Detalles -->
            <div class="col-12">
                <div class="card shadow-sm rounded-4">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                            <h5 class="fw-semibold mb-0">🧺 Productos del pedido</h5>
                            <span class="badge bg-dark">Items: @(Pedido.Detalles?.Count ?? 0)</span>
                        </div>

                        @if (Pedido.Detalles == null || Pedido.Detalles.Count == 0)
                        {
                            <div class="alert alert-warning mb-0">⚠️ Este pedido no tiene detalles cargados.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-bordered table-hover align-middle">
                                    <thead class="table-light text-center">
                                        <tr>
                                            <th>Producto</th>
                                            <th style="width:110px;">Cantidad</th>
                                            <th style="width:150px;">Precio unit.</th>
                                            <th style="width:150px;">Subtotal</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var d in Pedido.Detalles)
                                        {
                                            <tr @key="d.Id">
                                                <td>@d.Nombre</td>
                                                <td class="text-center">@d.Cantidad</td>
                                                <td class="text-end">$ @d.Precio_Unitario.ToString("N2")</td>
                                                <td class="text-end fw-semibold">$ @d.Subtotal.ToString("N2")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                    </div>
                </div>
            </div>

        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private Pedido? Pedido;
    private List<Estado_Pedido>? Estados;
    private string? Mensaje;
    private bool Cargando = true;

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    private async Task Cargar()
    {
        try
        {
            Mensaje = null;
            Cargando = true;

            // Estados (si existe el endpoint en tu proyecto actual)
            var respEstados = await http.Get<List<Estado_Pedido>>("api/Estado_Pedido");
            Estados = respEstados.Error ? new() : (respEstados.Respuesta ?? new());

            // Pedido
            var resp = await http.Get<Pedido>($"api/Pedido/{Id}");
            if (resp.Error)
            {
                Mensaje = await resp.ObtenerError();
                Pedido = null;
                return;
            }

            Pedido = resp.Respuesta;
        }
        finally
        {
            Cargando = false;
        }
    }

    private string EstadoDescripcion(int estadoId)
        => Estados?.FirstOrDefault(e => e.Id == estadoId)?.Descripcion ?? $"#{estadoId}";

    private void DescargarRecibo(int idPedido)
        => nav.NavigateTo($"api/Pedido/{idPedido}/recibo", true);
}
