@page "/InicioAdmin"
@* @page "/admin"  *@
@* @layout FabricaPastas.Client.Layout.AdminLayout *@
@* inject IJSRuntime JSRuntime *@
@inject NavigationManager navigationManager

<div class="container my-5 text-center">

    <nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm mb-4">
        <div class="container-fluid">

            <a class="navbar-brand fw-bold text-danger" href="/">🍝 La Nonna</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarNonna"
                    aria-controls="navbarNonna"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-center" id="navbarNonna">
                <ul class="navbar-nav gap-3">

                    <li class="nav-item">
                        <a class="nav-link active d-flex align-items-center gap-2 text-primary fw-bold" href="/InicioUsuario">
                            <i class="bi bi-house-door-fill"></i>Inicio
                        </a>
                    </li>

                   

                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center gap-2 text-danger fw-semibold" href="/LoginUsuarios" @onclick="CerrarSesion">
                            <i class="bi bi-box-arrow-right"></i>Salir
                        </a>
                    </li>

                </ul>
            </div>
        </div>
    </nav>

    <!-- Encabezado -->
    <h1 class="fw-bold text-danger mb-3">
        🛠️ Panel de Administración
    </h1>
    <p class="text-muted fs-5">
        Desde acá vas a poder administrar productos, listas de precios, pedidos y promociones.
    </p>

   
    <div class="row g-4 mt-4 justify-content-center">

        <!-- Productos -->
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-lg border-0 rounded-4 h-100">
                <div class="card-body">
                    <h5 class="card-title text-primary fw-semibold">
                        <i class="bi bi-box-seam-fill me-2"></i> Productos
                    </h5>
                    <p class="card-text text-muted">Crear, editar, listar, subir imagen.</p>
                    <a class="btn btn-outline-primary rounded-pill px-4 shadow-sm" href="/admin/productos">Acceder</a>
                </div>
            </div>
        </div>

        <!-- Listas de precio -->
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-lg border-0 rounded-4 h-100">
                <div class="card-body">
                    <h5 class="card-title text-success fw-semibold">
                        <i class="bi bi-cash-coin me-2"></i> Listas de precio
                    </h5>
                    <p class="card-text text-muted">Gestionar listas mayorista/minorista.</p>
                    <a class="btn btn-outline-success rounded-pill px-4 shadow-sm" href="/admin/detalle-lista-precio">Acceder</a>
                </div>
            </div>
        </div>

        <!-- Usuarios -->
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-lg border-0 rounded-4 h-100">
                <div class="card-body">
                    <h5 class="card-title text-info fw-semibold">
                        <i class="bi bi-people-fill me-2"></i> Usuarios
                    </h5>
                    <p class="card-text text-muted">Lista completa de usuarios.</p>
                    <a class="btn btn-outline-info rounded-pill px-4 shadow-sm" href="/admin/usuarios">Acceder</a>
                </div>
            </div>
        </div>

        <!-- Pedidos -->
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-lg border-0 rounded-4 h-100">
                <div class="card-body">
                    <h5 class="card-title text-warning fw-semibold">
                        <i class="bi bi-receipt-cutoff me-2"></i> Pedidos
                    </h5>
                    <p class="card-text text-muted">Lista completa, estado, filtros, detalle, PDF.</p>
                    <a class="btn btn-outline-warning rounded-pill px-4 shadow-sm" href="/admin/pedidos">Acceder</a>
                </div>
            </div>
        </div>

    </div>
</div>


@code{
    private async Task CerrarSesion()
    {
        // await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "usuarioNombre");
        navigationManager.NavigateTo("/LoginUsuarios");
    }
}