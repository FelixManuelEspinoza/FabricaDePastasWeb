@page "/InicioAdmin"
@page "/admin"
@layout FabricaPastas.Client.Layout.AdminLayout

<h1 class="mb-3">🛠️ Panel de Administración</h1>

<p class="text-muted">
    Desde acá vas a poder administrar productos, listas de precios, pedidos y promociones.
</p>

<div class="row g-3 mt-3">

    <div class="col-md-6 col-lg-4">
        <div class="card shadow-sm rounded-4">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-box-seam-fill me-2"></i>Productos</h5>
                <p class="card-text text-muted">Crear, editar, listar, subir imagen.</p>
                <a class="btn btn-primary" href="/admin/productos">Ir</a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="card shadow-sm rounded-4">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-cash-coin me-2"></i>Listas de precio</h5>
                <p class="card-text text-muted">Gestionar listas mayorista/minorista.</p>
                <a class="btn btn-primary" href="/admin/detalle-lista-precio">Ir</a>
            </div>
        </div>
    </div>

