@page "/Nosotros"

<div class="container my-5">

    <!-- Encabezado -->
    <div class="text-center mb-5">
        <h1 class="fw-bold text-warning display-5">
            <i class="bi bi-house-heart-fill me-2"></i> Nosotros
        </h1>
        <p class="text-muted fs-5">La historia y la pasión detrás de nuestra fábrica de pastas familiares.</p>
    </div>

    <!-- Sección: Imagen + texto -->
    <div class="row align-items-center mb-5">
        <div class="col-md-6 mb-4 mb-md-0">
            <img src="/Images/FabricaDePastas.jpg"
                 alt="Fábrica de pastas"
                 class="img-fluid rounded-4 shadow-lg">
        </div>

        <div class="col-md-6">
            <h3 class="text-danger fw-semibold mb-3">
                <i class="bi bi-journal-text me-2"></i> Nuestra Historia
            </h3>
            <p class="text-muted fs-5">
                Hace más de 20 años comenzamos como un pequeño taller familiar.
                Hoy somos una fábrica que combina <strong>tradición artesanal</strong> con <strong>tecnología moderna</strong>, ofreciendo pastas frescas y secas de la más alta calidad.
            </p>
            <p class="text-muted fs-5">
                Elaboramos <strong>ravioles rellenos</strong>, <strong>ñoquis de papa</strong>, <strong>tallarines al huevo</strong>, opciones <strong>integrales</strong> y <strong>sin gluten</strong>.
                También contamos con <strong>salsas caseras</strong> como pesto, bolognesa y cuatro quesos.
            </p>
        </div>
    </div>

    <!-- Misión y valores -->
    <div class="card border-0 shadow-lg rounded-4 mb-5">
        <div class="card-body p-4">
            <h3 class="card-title text-success fw-semibold mb-3">
                <i class="bi bi-heart-fill me-2"></i> Misión y Valores
            </h3>
            <ul class="list-unstyled text-muted fs-5">
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> Productos frescos y de calidad.</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> Tradición italiana en cada receta.</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> Opciones saludables e inclusivas.</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> Momentos de unión alrededor de la mesa.</li>
            </ul>
        </div>
    </div>

    <!-- Productos -->
    <div class="text-center mb-4">
        <h3 class="fw-bold text-warning">
            <i class="bi bi-basket-fill me-2"></i> Nuestros Productos
        </h3>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-sm h-100 rounded-4 border-0">
                <img src="/Images/Ravioles.jpg" class="card-img-top rounded-top-4" alt="Ravioles">
                <div class="card-body">
                    <h5 class="card-title text-danger">Ravioles</h5>
                    <p class="card-text text-muted">Rellenos de ricota y espinaca, elaborados con masa fresca.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100 rounded-4 border-0">
                <img src="/Images/Ñoquis.jpg" class="card-img-top rounded-top-4" alt="Ñoquis">
                <div class="card-body">
                    <h5 class="card-title text-danger">Ñoquis</h5>
                    <p class="card-text text-muted">Suaves y esponjosos, hechos con papa seleccionada.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100 rounded-4 border-0">
                <img src="/Images/Tallarines.jpg" class="card-img-top rounded-top-4" alt="Tallarines">
                <div class="card-body">
                    <h5 class="card-title text-danger">Tallarines</h5>
                    <p class="card-text text-muted">Clásicos al huevo, ideales para acompañar con nuestras salsas.</p>
                </div>
            </div>
        </div>
    </div>
</div>
