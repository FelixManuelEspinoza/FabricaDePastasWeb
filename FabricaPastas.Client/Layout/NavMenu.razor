
<div class="bg-light p-3 rounded shadow-sm">
    <nav class="nav flex-column gap-2">

        <!-- Inicio -->
        <NavLink class="nav-link d-flex align-items-center fw-semibold rounded-pill bg-dark text-white px-3 py-2 shadow-sm"
                 href="/" Match="NavLinkMatch.All">
            <i class="bi bi-house-door-fill me-2"></i> Inicio
        </NavLink>

        <!-- Catálogo -->
        <NavLink class="nav-link d-flex align-items-center fw-semibold rounded-pill bg-warning text-dark px-3 py-2 shadow-sm"
                 href="/Catalogo" Match="NavLinkMatch.All">
            <i class="bi bi-basket-fill me-2"></i> Catálogo
        </NavLink>

        <!-- Nosotros -->
        <NavLink class="nav-link d-flex align-items-center fw-semibold rounded-pill bg-info text-white px-3 py-2 shadow-sm"
                 href="/Nosotros" Match="NavLinkMatch.All">
            <i class="bi bi-people-fill me-2"></i> Nosotros
        </NavLink>

        <!-- FAQ -->
        <NavLink class="nav-link d-flex align-items-center fw-semibold rounded-pill bg-primary text-white px-3 py-2 shadow-sm"
                 href="/preguntas-frecuentes" Match="NavLinkMatch.All">
            <i class="bi bi-question-circle-fill me-2"></i> FAQ
        </NavLink>

        <!-- Sección usuarios -->
        <NavLink class="nav-link d-flex align-items-center fw-semibold rounded-pill bg-primary text-white px-3 py-2 shadow-sm"
                 href="/SeccionUsuarios" Match="NavLinkMatch.All">
            <i class="bi bi-box-arrow-in-right me-2"></i> Sección usuarios
        </NavLink>

        <!-- Opciones administrativas -->
        <NavLink class="nav-link d-flex align-items-center fw-semibold rounded-pill bg-light text-dark px-3 py-2 border"
                 href="/api/Lista_Precio/Crear" Match="NavLinkMatch.All">
            <i class="bi bi-cash-stack me-2 text-success"></i> Nueva Lista Precio
        </NavLink>

        <NavLink class="nav-link d-flex align-items-center fw-semibold rounded-pill bg-light text-dark px-3 py-2 border"
                 href="/api/Lista_Precio/Lista" Match="NavLinkMatch.All">
            <i class="bi bi-card-list me-2 text-success"></i> Lista Precio (L)
        </NavLink>

        <NavLink class="nav-link d-flex align-items-center fw-semibold rounded-pill bg-light text-dark px-3 py-2 border"
                 href="/api/Detalle_Lista_Precio/Crear" Match="NavLinkMatch.All">
            <i class="bi bi-file-earmark-plus me-2 text-primary"></i> Detalle Lista Precio
        </NavLink>

        <!-- Más opciones... -->
        <!-- Podés repetir el mismo estilo para Forma_Pago, Estado_Pedido, Categoría Producto, etc. -->

    </nav>

    <!-- Swagger -->
    <div class="mt-3">
        <NavLink class="nav-link d-flex align-items-center fw-semibold rounded-pill bg-light text-dark px-3 py-2 border shadow-sm"
                 href="https://localhost:7093/swagger" target="_blank">
            <i class="bi bi-code-slash me-2 text-primary"></i> Swagger
        </NavLink>
    </div>
</div>

@code {
  
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
