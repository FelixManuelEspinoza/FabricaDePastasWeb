@code {
    @* 
        Estado del menú (colapsar/expandir):
        - Hoy ToggleNavMenu no cambia la UI porque NavMenuCssClass no se usa en el markup.
        - Lo dejamos porque no rompe nada y más adelante lo conectamos si querés.
    *@
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
