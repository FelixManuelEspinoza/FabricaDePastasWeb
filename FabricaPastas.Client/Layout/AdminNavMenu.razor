<style>
    .brand-text {
        color: #ff2f2f;
        font-weight: 800;
        letter-spacing: 0.2px;
    }

    .nav-link.active {
        font-weight: 700;
        text-decoration: underline;
        text-underline-offset: 6px;
    }
</style>

@code {
    private async Task CerrarSesion()
    {
        // Limpieza completa (porque ahora hay JWT)
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "usuarioNombre");
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "usuarioId");
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "usuarioRol");
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "usuarioTipoCliente");
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "authToken");

        Nav.NavigateTo("/LoginUsuarios", true);
    }
}
