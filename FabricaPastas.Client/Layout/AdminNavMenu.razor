        </a>

        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#adminTopNav"
                aria-controls="adminTopNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="adminTopNav">
            <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">

                <li class="nav-item">
                    <NavLink class="nav-link" href="/admin" Match="NavLinkMatch.All">
                        <i class="bi bi-house-gear-fill me-2"></i>Inicio Admin
                    </NavLink>
                </li>

                <li class="nav-item">
                    <NavLink class="nav-link" href="/admin/productos">
                        <i class="bi bi-box-seam-fill me-2"></i>Productos
                    </NavLink>
                </li>

                <li class="nav-item">
                    <NavLink class="nav-link" href="/admin/detalle-lista-precio">
                        <i class="bi bi-cash-coin me-2"></i>Listas de precio
                    </NavLink>
                </li>
@* 
                <li class="nav-item">
                    <NavLink class="nav-link" href="/admin/detalle-lista-precio">
                        <i class="bi bi-tags-fill me-2"></i>Detalle lista
                    </NavLink>

                </li> *@



                <li class="nav-item">
                    <NavLink class="nav-link" href="/admin/usuarios">
                        <i class="bi bi-people-fill me-2"></i>Usuarios
                    </NavLink>
                </li>


                <li class="nav-item">
                    <NavLink class="nav-link" href="/api/Pedido/ListaSB">
