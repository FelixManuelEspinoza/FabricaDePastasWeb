                </li>

@*                 <li class="nav-item">
                    <NavLink class="nav-link" href="/admin/promociones">
                        <i class="bi bi-stars me-2"></i>Promociones
                    </NavLink>
                </li> *@

                <li class="nav-item">
                    <a class="nav-link text-danger fw-semibold" href="#" @onclick="CerrarSesion">
